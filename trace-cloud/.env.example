# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://trace:trace_dev_pw@localhost:5432/trace_cloud

# ── Redis / Queue ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_in_production_32chars_min
JWT_REFRESH_SECRET=change_me_in_production_32chars_min_refresh

# ── RTrace engine ────────────────────────────────────────────────────────────
# Point to the plumber API. If unset, the worker falls back to Rscript subprocess.
RTRACE_API_URL=http://localhost:8394

# ── API server ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
