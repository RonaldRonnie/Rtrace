generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users & Auth ──────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships  OrgMember[]
  scansTriggered Scan[]
  apiKeys      ApiKey[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  keyPrefix   String
  userId      String
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// ── Organizations ─────────────────────────────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  plan        Plan     @default(FREE)
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members  OrgMember[]
  projects Project[]

  @@map("organizations")
}

enum Plan {
  FREE
  TEAM
  BUSINESS
  ENTERPRISE
}

model OrgMember {
  id     String   @id @default(cuid())
  role   OrgRole  @default(MEMBER)
  joinedAt DateTime @default(now())

  orgId  String
  userId String

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@map("org_members")
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ── Projects ──────────────────────────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  name        String
  slug        String
  description String?
  repoUrl     String?
  scanRoot    String   @default(".")
  defaultBranch String @default("main")
  badgeToken     String   @unique @default(cuid())
  webhookSecret  String?
  scheduledCron  String?  // cron expression for scheduled scans, e.g. "0 2 * * *"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  scans Scan[]

  @@unique([orgId, slug])
  @@map("projects")
}

// ── Scans ─────────────────────────────────────────────────────────────────────

model Scan {
  id          String     @id @default(cuid())
  status      ScanStatus @default(PENDING)
  branch      String?
  commitSha   String?
  triggeredBy String?    // "manual" | "api" | "webhook"
  startedAt   DateTime?
  finishedAt  DateTime?
  errorMessage String?

  // Aggregate scores
  overallScore   Int?
  overallLabel   String?

  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  moduleScores ScanModuleScore[]
  diagnostics  Diagnostic[]

  @@map("scans")
}

enum ScanStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

model ScanModuleScore {
  id             String @id @default(cuid())
  moduleId       String
  moduleName     String
  score          Int
  label          String
  errorCount     Int    @default(0)
  warningCount   Int    @default(0)
  infoCount      Int    @default(0)

  scanId String
  scan   Scan   @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@map("scan_module_scores")
}

model Diagnostic {
  id         String @id @default(cuid())
  ruleId     String
  severity   String
  file       String
  line       Int?
  column     Int?
  message    String
  suggestion String?
  moduleId   String

  scanId String
  scan   Scan   @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId, severity])
  @@index([scanId, ruleId])
  @@map("diagnostics")
}
